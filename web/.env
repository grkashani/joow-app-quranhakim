# JoowQuran build-time env (loaded in ALL Vite modes). Only VITE_-prefixed vars reach the
# bundle, and every value below is a PUBLIC identifier (safe to ship). NEVER put SESSION_SECRET
# or the Apple .p8 here — those are server-only secrets.
#
# Empty values are intentional: the app builds and renders with them, but the sign-in buttons
# stay inert until the owner fills in real IDs (see the deliverable "credentials owner must
# create" table). Do not commit real values here if you prefer — use .env.local (gitignored).

# Apple Services ID (web Sign in with Apple), e.g. com.joow.quran.web
VITE_APPLE_SERVICE_ID_WEB=
# Apple return URL registered on the Services ID
VITE_APPLE_REDIRECT_URI=https://quranner.com/auth/apple/callback
# Google Web OAuth client id (…apps.googleusercontent.com) — used by GIS on web + as server client on native
VITE_GOOGLE_CLIENT_ID_WEB=
# Google iOS OAuth client id (…apps.googleusercontent.com) — native only
VITE_GOOGLE_CLIENT_ID_IOS=
# Backend origin: '' on the web build (same-origin), https://quranner.com on native (.env.capacitor)
VITE_AUDIO_BASE=
# JooW super-app shell origin — the EXACT origin that frames the reader as a
# mini-app. The SDK bridge pins it on every postMessage (see src/lib/shell.js).
# Empty = derive from the framing document's referrer at runtime. Set explicitly
# for a hardened build, e.g. https://stage.joow.org (stage) / https://joow.org (prod).
VITE_JOOW_HOST_ORIGIN=
