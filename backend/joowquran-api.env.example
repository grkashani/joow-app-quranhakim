# Copy to /etc/joowquran-api.env on the server and fill in your keys.
# ElevenLabs Speech-to-Text (Scribe) — REQUIRED for transcription.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2

# Optional: enables on-demand translation of transcripts into other languages.
# Without it, non-original languages return the original transcript.
ANTHROPIC_API_KEY=
TRANSLATE_MODEL=claude-haiku-4-5-20251001

PORT=8787
WEBROOT=/var/www/quranner
